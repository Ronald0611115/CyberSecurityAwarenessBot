п»ҝ<Window x:Class="CyberSecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Awareness Bot"
        Height="650" Width="850"
        MinHeight="500" MinWidth="600"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Colours -->
        <SolidColorBrush x:Key="BotBubble"    Color="#2A2A3E"/>
        <SolidColorBrush x:Key="UserBubble"   Color="#3A3A5C"/>
        <SolidColorBrush x:Key="AccentGreen"  Color="#00FF9C"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#888899"/>
        <SolidColorBrush x:Key="InputBg"      Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BorderColour" Color="#3A3A5C"/>

        <!-- Input TextBox style -->
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"   Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderColour}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="Padding"      Value="12,10"/>
            <Setter Property="CaretBrush"   Value="{StaticResource AccentGreen}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Send Button style -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource AccentGreen}"/>
            <Setter Property="Foreground"  Value="#1E1E2E"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="20,10"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00CC7A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="*"/>
            <!-- Chat area -->
            <RowDefinition Height="Auto"/>
            <!-- Input bar -->
        </Grid.RowDefinitions>

        <!-- в•җв•җв•җ HEADER в•җв•җв•җ -->
        <Border Grid.Row="0"
                Background="#16213E"
                BorderBrush="{StaticResource BorderColour}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <StackPanel>
                <!-- ASCII Art -->
                <TextBlock FontFamily="Courier New"
                           FontSize="11"
                           Foreground="{StaticResource AccentGreen}"
                           Text="в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—      в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
                           &#x0a;в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ     в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—    в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ
                           &#x0a;в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—       в–Ҳв–Ҳв•‘      в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   
                           &#x0a;в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•җв•җв•қ       в–Ҳв–Ҳв•‘       в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—    в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   
                           &#x0a;в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘   
                           &#x0a;в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ      в•ҡв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ    в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ    в•ҡв•җв•қ   "/>    
                <!-- Subtitle -->
                <TextBlock Text="Blake Your personal cybersecurity assistant вҖ” stay safe online."
                           Foreground="{StaticResource TextMuted}"
                           FontSize="12"
                           Margin="4,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- в•җв•җв•җ CHAT DISPLAY в•җв•җв•җ -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12">
            <StackPanel x:Name="ChatPanel"
                        VerticalAlignment="Bottom"/>
        </ScrollViewer>

        <!-- в•җв•җв•җ INPUT BAR в•җв•җв•җ -->
        <Border Grid.Row="2"
                Background="#16213E"
                BorderBrush="{StaticResource BorderColour}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         x:Name="UserInputBox"
                         Style="{StaticResource InputStyle}"
                         ToolTip="Type your message here..."
                         KeyDown="UserInputBox_KeyDown"
                         Margin="0,0,10,0"/>

                <Button Grid.Column="1"
                        x:Name="SendButton"
                        Content="Send"
                        Style="{StaticResource SendButtonStyle}"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
