п»ҝ<Window x:Class="CyberSecurityAwarenessBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="700" Width="950"
        MinHeight="550" MinWidth="750"
        Background="#1E1E2E"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <SolidColorBrush x:Key="BotBubble"    Color="#2A2A3E"/>
        <SolidColorBrush x:Key="UserBubble"   Color="#3A3A5C"/>
        <SolidColorBrush x:Key="Lavender"     Color="Lavender"/>
        <SolidColorBrush x:Key="TextPrimary"  Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextMuted"    Color="#888899"/>
        <SolidColorBrush x:Key="InputBg"      Color="#2A2A3E"/>
        <SolidColorBrush x:Key="BorderColour" Color="#3A3A5C"/>
        <SolidColorBrush x:Key="TabBg"        Color="#16213E"/>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background"   Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"  Value="{StaticResource BorderColour}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="Padding"      Value="12,10"/>
            <Setter Property="CaretBrush"   Value="{StaticResource Lavender}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource Lavender}"/>
            <Setter Property="Foreground"  Value="#1E1E2E"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"     Value="20,10"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00CC7A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource TabBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderColour}"
                                BorderThickness="0,0,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1E1E2E"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentGreen}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <TabControl Background="#16213E" BorderThickness="0">

        <!-- TAB 1: CHAT вҖ” Parts 1 & 2, unchanged -->
        <TabItem Header="Chat">
            <Grid Background="#1E1E2E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#16213E"
                        BorderBrush="{StaticResource BorderColour}"
                        BorderThickness="0,0,0,1"
                        Padding="20,14">
                    <StackPanel>
                        <TextBlock FontFamily="Courier New"
                                   FontSize="11"
                                   Foreground="{StaticResource Lavender}"
                                   Text=" в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
                                   &#x0a;в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—    в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ
                                   &#x0a;в–Ҳв–Ҳв•‘      в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   
                                   &#x0a;в–Ҳв–Ҳв•‘       в•ҡв–Ҳв–Ҳв•”в•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•қ  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—    в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   
                                   &#x0a;в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘    в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘   
                                   &#x0a; в•ҡв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ    в•ҡв•җв•җв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•қ    в•ҡв•җв•қ   "/>
                        <TextBlock Text="Your personal cybersecurity assistant вҖ” stay safe online."
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="12"
                                   Margin="4,4,0,0"/>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Row="1"
                              x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,12">
                    <StackPanel x:Name="ChatPanel" VerticalAlignment="Bottom"/>
                </ScrollViewer>

                <Border Grid.Row="2"
                        Background="#16213E"
                        BorderBrush="{StaticResource BorderColour}"
                        BorderThickness="0,1,0,0"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="UserInputBox"
                                 Style="{StaticResource InputStyle}"
                                 ToolTip="Type your message here..."
                                 KeyDown="UserInputBox_KeyDown"
                                 Margin="0,0,10,0"/>

                        <Button Grid.Column="1"
                                x:Name="SendButton"
                                Content="Send"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="SendButton_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>

        <!-- TAB 2: TASKS вҖ” built in Step 3 -->
        <TabItem Header="Tasks">
            <Grid Background="#1E1E2E" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                   Text="Task Assistant"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource AccentGreen}"
                   Margin="0,0,0,16"/>

                <!-- Add Task Form -->
                <Border Grid.Row="1"
                Background="#16213E"
                BorderBrush="{StaticResource BorderColour}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16"
                Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Task Title" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TaskTitleBox" Style="{StaticResource InputStyle}" Margin="0,0,0,10"/>

                        <TextBlock Text="Description" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="TaskDescriptionBox"
                         Style="{StaticResource InputStyle}"
                         Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                         Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Reminder Date (optional)" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,4"/>
                                <DatePicker x:Name="TaskReminderPicker" Width="200" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                            Content="Add Task"
                            Style="{StaticResource ActionButtonStyle}"
                            VerticalAlignment="Bottom"
                            Click="AddTaskButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Task List -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TaskListPanel"/>
                </ScrollViewer>
            </Grid>
        </TabItem>

        <!-- TAB 3: QUIZ вҖ” built in Step 4 -->
        <TabItem Header="Quiz">
            <Grid Background="#1E1E2E" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                   Text="Cybersecurity Quiz"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource AccentGreen}"
                   Margin="0,0,0,16"/>

                <Border Grid.Row="1"
                Background="#16213E"
                BorderBrush="{StaticResource BorderColour}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="24"
                VerticalAlignment="Top">
                    <StackPanel x:Name="QuizContentPanel">
                        <!-- Built dynamically in code-behind -->
                    </StackPanel>
                </Border>
            </Grid>
        </TabItem>

        <!-- TAB 4: ACTIVITY LOG вҖ” built in Step 5/6 -->
        <TabItem Header="Activity Log">
            <Grid Background="#1E1E2E" Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Activity Log"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{StaticResource AccentGreen}"
                           Margin="0,0,0,16"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="ActivityLogPanel"/>
                </ScrollViewer>
            </Grid>
        </TabItem>

    </TabControl>
</Window>
